<script>
  document.addEventListener("DOMContentLoaded", () => {
    // grab constructor from global
    const CountUpCtor = (window.countUp && window.countUp.CountUp) || window.CountUp;

    const c1 = new CountUpCtor('counter1', 282, { duration: 2 });
    const c2 = new CountUpCtor('counter2', 7281, { duration: 2 });
    const c3 = new CountUpCtor('counter3', 3.46, { duration: 2, decimalPlaces: 2 });

    const section = document.getElementById("stats-section");

    const observer = new IntersectionObserver((entries, obs) => {
      if (entries[0].isIntersecting) {
        if (!c1.error) c1.start();
        if (!c2.error) c2.start();
        if (!c3.error) c3.start();
        obs.disconnect(); // run only once
      }
    }, { threshold: 0.3 });

    observer.observe(section);
  });
</script>