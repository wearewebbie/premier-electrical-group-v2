<script>
  function scrollTimeline(direction) {
    const timeline = document.getElementById('timeline');
    const scrollAmount = 380;
    timeline.scrollBy({
      left: direction * scrollAmount,
      behavior: 'smooth'
    });
  }

  document.addEventListener("DOMContentLoaded", () => {
    // grab constructor from global
    const CountUpCtor = (window.countUp && window.countUp.CountUp) || window.CountUp;

    const c1 = new CountUpCtor('counter1', 1018, { duration: 2 });
    const c2 = new CountUpCtor('counter2', 24934, { duration: 2 });
    const c3 = new CountUpCtor('counter3', 11.17, { duration: 2, decimalPlaces: 2 });

    const section = document.getElementById("stats-section");

    const observer = new IntersectionObserver((entries, obs) => {
      if (entries[0].isIntersecting) {
        if (!c1.error) c1.start();
        if (!c2.error) c2.start();
        if (!c3.error) c3.start();
        obs.disconnect(); // run only once
      }
    }, { threshold: 0.3 });

    observer.observe(section);
  });
</script>