<section class="bg-navy-1000">
  <div class="container gap-[112px]">
    <div class="flex flex-col">
      <div class="flex flex-col gap-[16px] pb-[100px] pt-[20px]">
        <div class="flex flex-col accordion w-full gap-[16px]">
          {% for item in accordionItems %}
          <div class="w-full flex flex-col border-b border-navy-200
            {% if loop.first %} pt-[20px] {% endif %} pb-[20px]
              {% if loop.first %} border-t {% endif %}">

            <button
              class="accordion-header w-full flex justify-between gap-[12px] items-center text-left cursor-pointer"
              aria-expanded="{% if loop.first %}true{% else %}false{% endif %}" data-accordion-trigger>
              <span class="subheading-regular text-cyan-1000">{{ item.title }}</span>
              <img data-icon-plus src="/assets/svgs/plus-circle.png" alt="Expand"
                class="lg:w-[30px] lg:h-[30px] w-[20px] h-[20px] {% if loop.first %}hidden{% else %}block{% endif %}" />
              <img data-icon-minus src="/assets/svgs/minus-circle.png" alt="Collapse"
                class="lg:w-[30px] lg:h-[30px] w-[20px] h-[20px] {% if loop.first %}block{% else %}hidden{% endif %}" />
            </button>

            <div
              class="w-full accordion-content overflow-hidden transition-[max-height] duration-500 ease-in-out flex flex-col gap-[20px]"
              data-accordion-content style="max-height: 0">
              <div class="w-full lg:w-[800px] title-medium text-navy-400 flex flex-col">
                {% if item.subtitle %}
                {{ item.subtitle | safe }}
                {% endif %}
              </div>
              <div class="w-full lg:w-[800px] text-lg-regular text-navy-200 gap-[20px] flex flex-col">
                {% if item.items %}
                <div class="grid grid-cols-2 lg:grid-cols-3 gap-[40px]">
                  {% for listItem in item.items %}
                  <div class="flex flex-col items-start gap-[12px]">
                    <div class="w-8 h-8">
                      {{ listItem.svg | safe }}
                    </div>
                    <p class="text-lg-medium text-navy-0 leading-[8px]!">{{ listItem.title }}</p>
                    <p class="text-lg-regular text-navy-400">{{ listItem.description }}</p>
                  </div>
                  {% endfor %}
                </div>
                {% else %}
                {% for para in item.content %}
                <p>{{ para | safe }}</p>
                {% endfor %}
                {% endif %}
              </div>
            </div>
          </div>
          {% endfor %}
        </div>

        <script>
          document.addEventListener("DOMContentLoaded", () => {
            document.querySelectorAll("[data-accordion-trigger]").forEach((button, index) => {
              const content = button.nextElementSibling;
              const iconPlus = button.querySelector("[data-icon-plus]");
              const iconMinus = button.querySelector("[data-icon-minus]");

              if (index === 0) {
                content.style.maxHeight = content.scrollHeight + "px";
                button.setAttribute("aria-expanded", "true");
                iconPlus.classList.add("hidden");
                iconMinus.classList.remove("hidden");
              }

              button.addEventListener("click", () => {
                const isExpanded = button.getAttribute("aria-expanded") === "true";

                if (isExpanded) {
                  content.style.maxHeight = "0";
                  button.setAttribute("aria-expanded", "false");
                  iconPlus.classList.remove("hidden");
                  iconMinus.classList.add("hidden");
                } else {
                  content.style.maxHeight = content.scrollHeight + "px";
                  button.setAttribute("aria-expanded", "true");
                  iconPlus.classList.add("hidden");
                  iconMinus.classList.remove("hidden");
                }
              });
            });
          });
        </script>
      </div>
    </div>
</section>

