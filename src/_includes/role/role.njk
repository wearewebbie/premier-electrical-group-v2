---
layout: base/base.njk
title: "{{ title }} | Premier Electrical Group Careers"
description: "{{ title }} — {{ location }}. Join the team at Premier Electrical Group."
---

<section class="relative bg-[url(/assets/images/landing.webp)] bg-no-repeat bg-cover bg-center">
    <div class="bg-[#001125]/50">
        <div class="container mx-auto">
            <div class="w-full pt-[140px] pb-[60px] flex flex-col gap-[40px]">
                <h1 class="subheading-regular !font-semibold text-navy-0">{{ title }}</h1>
                <div class="flex flex-row gap-[20px] items-center">
                    <div class="flex flex-row gap-[10px] items-center">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-[18px]">
                            <path
                                d="M12 13C13.6569 13 15 11.6569 15 10C15 8.34315 13.6569 7 12 7C10.3431 7 9 8.34315 9 10C9 11.6569 10.3431 13 12 13Z"
                                stroke="#B7D6E2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                            <path
                                d="M12 22C16 18 20 14.4183 20 10C20 5.58172 16.4183 2 12 2C7.58172 2 4 5.58172 4 10C4 14.4183 8 18 12 22Z"
                                stroke="#B7D6E2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <p class="text-cyan-1000 text-sm-light">{{ location }}</p>
                    </div>
                    <div class="flex flex-row gap-[10px]">
                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-[18px]">
                            <path
                                d="M21 10H3M16 2V6M8 2V6M7.8 22H16.2C17.8802 22 18.7202 22 19.362 21.673C19.9265 21.3854 20.3854 20.9265 20.673 20.362C21 19.7202 21 18.8802 21 17.2V8.8C21 7.11984 21 6.27976 20.673 5.63803C20.3854 5.07354 19.9265 4.6146 19.362 4.32698C18.7202 4 17.8802 4 16.2 4H7.8C6.11984 4 5.27976 4 4.63803 4.32698C4.07354 4.6146 3.6146 5.07354 3.32698 5.63803C3 6.27976 3 7.11984 3 8.8V17.2C3 18.8802 3 19.7202 3.32698 20.362C3.6146 20.9265 4.07354 21.3854 4.63803 21.673C5.27976 22 6.11984 22 7.8 22Z"
                                stroke="#B7D6E2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <p class="text-cyan-1000 text-sm-light">{{ contract }}</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{% block body %}
<section class="bg-white-100">
    <div class="container py-[60px] lg:py-[100px] min-h-screen">
        <div class="flex flex-col lg:flex-row gap-[60px]">
            <div class="markdown-isolated">
                <article>
                    {{ about | safe }}

                    <h2>Role Overview</h2>
                    {{ overview | safe }}

                    <h2>Key Responsibilities</h2>
                    <ul>
                        {% for item in responsibilities %}<li>{{ item }}</li>{% endfor %}
                    </ul>

                    <h2>Essential</h2>
                    <ul>
                        {% for item in essential %}<li>{{ item }}</li>{% endfor %}
                    </ul>

                    {% if desirable and desirable | length %}
                    <h2>Desirable</h2>
                    <ul>
                        {% for item in desirable %}<li>{{ item }}</li>{% endfor %}
                    </ul>
                    {% endif %}

                    <h2>Benefits</h2>
                    <ul>
                        {% for item in benefits %}<li>{{ item }}</li>{% endfor %}
                    </ul>
                </article>
            </div>
        </div>
    </div>
</section>
{% endblock %}

<section class="bg-navy-1000">
    <div class="container py-[100px]">
        <div class="flex flex-col gap-[40px]">
            <h2 class="subheading-regular text-cyan-1000">Apply Now</h2>
            <p class="text-lg-regular text-cyan-0">Ready to take the next step in your career? Fill out the form below
                and we'll get back to you soon.</p>

            <iframe src="https://app.premierelectricalgroup.co.uk/widget/form/MvtDAMo9gm7AJIrSi2ju?applied_role={{ title | urlencode }}"
                style="width:100%;height:100%;border:none;border-radius:3px" id="inline-MvtDAMo9gm7AJIrSi2ju"
                data-layout="{'id':'INLINE'}" data-trigger-type="alwaysShow" data-trigger-value=""
                data-activation-type="alwaysActivated" data-activation-value="" data-deactivation-type="neverDeactivate"
                data-deactivation-value="" data-form-name="CV Form" data-height="512"
                data-layout-iframe-id="inline-MvtDAMo9gm7AJIrSi2ju" data-form-id="MvtDAMo9gm7AJIrSi2ju" title="CV Form">
            </iframe>
        </div>
    </div>
</section>

<script src="https://app.premierelectricalgroup.co.uk/js/form_embed.js"></script>