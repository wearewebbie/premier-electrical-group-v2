---
layout: base/base.njk
title: "{{ title }} | Premier Electrical Group Careers"
description: "{{ title }} — {{ location }}. Join the team at Premier Electrical Group."
---

<section class="relative bg-[url(/assets/images/landing.webp)] bg-no-repeat bg-cover bg-center">
    <div class="bg-[#001125]/50">
        <div class="container mx-auto">
            <div class="w-full pt-[140px] pb-[60px] flex flex-col gap-[40px]">
                <h1 class="heading-semibold text-navy-0">{{ title }}</h1>
                <div class="flex flex-row gap-[20px] items-center">
                    <div class="flex flex-row gap-[10px] items-center">
                        <img src="/assets/svgs/tools.svg" alt="" class="w-[18px] text-navy-1000" />
                        <p class="text-cyan-1000 text-sm-light">{{ location }}</p>
                    </div>
                    <div class="flex flex-row gap-[10px]">
                        <img src="/assets/svgs/tools.svg" alt="" class="w-[18px] text-navy-1000" />
                        <p class="text-cyan-1000 text-sm-light">{{ contract }}</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{% block body %}
<div class="container py-[60px] lg:py-[100px] min-h-screen">
    <div class="flex flex-col lg:flex-row gap-[60px]">
        <div class="lg:w-2/3">
            <div class="markdown-isolated">
                <article>
                    {{ about | safe }}

                    <h2>Role Overview</h2>
                    {{ overview | safe }}

                    <h2>Key Responsibilities</h2>
                    <ul>
                        {% for item in responsibilities %}<li>{{ item }}</li>{% endfor %}
                    </ul>

                    <h2>Essential</h2>
                    <ul>
                        {% for item in essential %}<li>{{ item }}</li>{% endfor %}
                    </ul>

                    {% if desirable and desirable | length %}
                    <h2>Desirable</h2>
                    <ul>
                        {% for item in desirable %}<li>{{ item }}</li>{% endfor %}
                    </ul>
                    {% endif %}

                    <h2>Benefits</h2>
                    <ul>
                        {% for item in benefits %}<li>{{ item }}</li>{% endfor %}
                    </ul>
                </article>
            </div>
        </div>
        <div
            class="flex flex-col bg-navy-1000 px-[20px] rounded-[4px] py-[40px] lg:w-1/3 lg:self-start sticky top-[120px]">
            <h2 class="title-medium text-cyan-1000 mb-6">Apply Now</h2>
            <iframe src="https://app.premierelectricalgroup.co.uk/widget/form/MvtDAMo9gm7AJIrSi2ju"
                style="width:100%;height:100%;border:none;border-radius:3px" id="inline-MvtDAMo9gm7AJIrSi2ju"
                data-layout="{'id':'INLINE'}" data-trigger-type="alwaysShow" data-trigger-value=""
                data-activation-type="alwaysActivated" data-activation-value="" data-deactivation-type="neverDeactivate"
                data-deactivation-value="" data-form-name="CV Form" data-height="512"
                data-layout-iframe-id="inline-MvtDAMo9gm7AJIrSi2ju" data-form-id="MvtDAMo9gm7AJIrSi2ju" title="CV Form">
            </iframe>
        </div>
    </div>
</div>
{% endblock %}

<script src="https://app.premierelectricalgroup.co.uk/js/form_embed.js"></script>