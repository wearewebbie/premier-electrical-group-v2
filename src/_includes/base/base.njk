<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Title -->
  <title>
    {%- if title %}{{ title }} | {{ site.title }}{%- else %}{{ site.title }}{%- endif %}
  </title>

  <!-- Primary Meta -->
  <meta name="description" content="{{ description or site.description }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ title or site.title }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  {%- if site.image %}
  <meta property="og:image" content="{{ site.url }}{{ site.image }}">
  {%- endif %}

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title or site.title }}">
  <meta name="twitter:description" content="{{ description or site.description }}">
  {%- if site.image %}
  <meta name="twitter:image" content="{{ site.url }}{{ site.image }}">
  {%- endif %}

  <!-- Icons -->
  <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="apple-mobile-web-app-title" content="PEG" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#ffffff">

  <!-- Styles -->
  <link rel="stylesheet" href="/css/bundle.css">

  <!-- Swiper -->
  <link rel="stylesheet" href="/assets/swiper/swiper-bundle.min.css" />
  <script src="/assets/swiper/swiper-bundle.min.js" defer></script>

  <!-- Structured Data -->
  <script type="application/ld+json">

{
  "@context": "https://schema.org",
  "@type": "{{ site.schemaType or 'LocalBusiness' }}",
  "name": "{{ site.title }}",
  "url": "{{ site.url }}",
  "description": "{{ site.description }}"
  {%- if site.logo %},
  "logo": "{{ site.url }}{{ site.logo }}"
  {%- endif %}
  {%- if site.image %},
  "image": "{{ site.url }}{{ site.image }}"
  {%- endif %}
  {%- if site.phone %},
  "telephone": "{{ site.phone }}"
  {%- endif %}
  {%- if site.email %},
  "email": "{{ site.email }}"
  {%- endif %}
  {%- if site.social and site.social | length %},
  "sameAs": [
    {%- for key, value in site.social %}
      "{{ value }}"{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
  {%- endif %}
}
  </script>

  <!-- Custom Scripts -->
  <script id="Cookiebot" src="https://consent.cookiebot.com/uc.js" data-cbid="fc068b27-7c86-460d-bf59-77ebe2326cf6"
    data-blockingmode="auto" type="text/javascript"></script>
  <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18008034566"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'AW-18008034566');
  </script>

</head>

<body class="scroll-smooth">

  <a href="#main-content" class="sr-only focus:not-sr-only">
    Skip to content
  </a>

  {% include "header/header.njk" %}

  <main id="main-content">
    {{- content | safe }}
  </main>

  {% include "footer/footer.njk" %}

  {% include "chatbot/chatbot.njk" %}

</body>

<!-- Custom Scripts -->
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script src="https://cdn.jsdelivr.net/npm/countup.js@2.9.0/dist/countUp.umd.js"></script>
<script src="https://cdn.jsdelivr.net/npm/embla-carousel@8.1.6/embla-carousel.umd.js"></script>
<script>function loadScript(a) { var b = document.getElementsByTagName("head")[0], c = document.createElement("script"); c.type = "text/javascript", c.src = "https://tracker.metricool.com/resources/be.js", c.onreadystatechange = a, c.onload = a, b.appendChild(c) } loadScript(function () { beTracker.t({ hash: "6af774161c1092e03ed8c2d136c07fc0" }) });</script>
<script>
  document.querySelectorAll('#redirect').forEach(input => {
    input.value = `${window.location.origin}/success`;
  });
</script>
<script src="https://link.msgsndr.com/js/form_embed.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.13.0/dist/ScrollTrigger.min.js"></script>

</html>