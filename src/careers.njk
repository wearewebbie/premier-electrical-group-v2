<section class="bg-navy-1000">
  <div class="container pb-[100px]">
    <div class="flex flex-col gap-[40px]">
      <h2 class="subheading-regular text-cyan-1000">Don't see the right role?</h2>
      <p class="text-lg-regular text-cyan-0">We're always looking for talented individuals to join our team. Send us
        your CV and we'll keep you in mind for future opportunities.</p>

      <div class="flex flex-col gap-[20px]">
        <div class="flex flex-col lg:flex-row gap-[20px]">
          <div class="input-group flex-1">
            <label for="name" class="block text-sm-regular text-navy-0">Name*</label>
            <input type="text" pattern="^[A-Za-zÀ-ÖØ-öø-ÿ' -]{2,50}$" maxlength="50" required id="name" name="name"
              placeholder="Name" class="input input-placeholder text-navy-0" />
          </div>
          <div class="input-group flex-1">
            <label for="name" class="block text-sm-regular text-navy-0">Email*</label>
            <input type="text" pattern="^[A-Za-zÀ-ÖØ-öø-ÿ' -]{2,50}$" maxlength="50" required id="name" name="name"
              placeholder="Name" class="input input-placeholder text-navy-0" />
          </div>
        </div>
        <div class="input-group">
          <label for="cv" class="block text-sm-regular text-navy-0">Resume / CV*</label>
          <label for="cv"
            class="flex flex-col items-center justify-center gap-[8px] border-[1px] border-dashed border-navy-600 rounded-[4px] p-[24px] cursor-pointer text-center transition-colors hover:border-cyan-1000">
            <svg class="w-[24px] h-[24px] text-navy-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
              stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M12 16.5V9.75m0 0-3 3m3-3 3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z" />
            </svg>
            <span id="cv-filename" class="text-sm-regular text-navy-400">Click to upload CV</span>
            <input type="file" id="cv" name="cv" accept=".pdf,.doc,.docx" required class="hidden" />
          </label>
        </div>
        <div class="flex items-center justify-between">
          <p class="text-xs-light  text-navy-0">Required*</p>
          <button class="button-primary cursor-pointer">Submit</button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
