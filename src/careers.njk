<!-- Header-->
<section class="relative bg-[url(/assets/images/landing.webp)] bg-no-repeat bg-cover bg-center">
  <div class="bg-[#001125]/50">
    <div class="container mx-auto flex items-end min-h-[440px]">
      <div class="flex flex-col gap-[20px] py-[100px]">
        <h1 class="heading-semibold text-navy-0">Careers</h1>
        <h2 class="title-regular text-navy-0">Join the team powering Northern Ireland's energy future</h2>
      </div>
    </div>
  </div>
</section>

<!-- Who we are -->
<section class="bg-navy-1000">
  <div class="container pt-[100px] pb-[50px]">
    <div class="flex flex-col gap-[40px]">
      <h2 class="subheading-regular text-cyan-1000">Our Core Values.</h2>
      <p class="text-lg-regular text-cyan-0"> At Premier Electrical Group, we're passionate about helping homes,
        businesses and farms make the switch to solar energy. We design and install high-quality solar solutions that
        help our customers save money, become more energy independent and reduce their environmental impact.</p>

      <p class="text-lg-regular text-cyan-0"> We're a growing team that takes pride in doing things the right way. We
        believe in quality workmanship, great
        customer service and creating a positive place to work. If you're hardworking, motivated and want to be part
        of
        a company that's helping shape a more sustainable future, we'd love to hear from you.</p>
    </div>
  </div>
</section>

<!-- Why work here -->
<section class="bg-navy-1000">
  <div class="container pt-[50px] pb-[100px]">
    <div class="flex flex-col gap-[100px]">
      <div class="flex flex-col gap-[40px]">
        <h2 class="subheading-regular text-cyan-1000">Why Work Here</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-[40px]">
          <div class="flex flex-col gap-[20px]">
            <img src="/assets/svgs/agriculture.svg" alt="" class="w-[32px]" />
            <h3 class="heading-regular text-cyan-1000">Training & Development</h3>
            <p class="text-lg-regular text-cyan-0">We encourage continuous learning with ongoing training,
              certifications, and hands-on experience across a variety of commercial and industrial projects.
            </p>
          </div>
          <div class="flex flex-col gap-[20px]">
            <img src="/assets/svgs/agriculture.svg" alt="" class="w-[32px]" />
            <h3 class="heading-regular text-cyan-1000">Good People, Great Culture</h3>
            <p class="text-lg-regular text-cyan-0">We work hard, but we also make time to enjoy ourselves. From team
              outings and social events to celebrating milestones together, we're building a workplace where people
              genuinely enjoy being part of the team.
            </p>
          </div>
          <div class="flex flex-col gap-[20px]">
            <img src="/assets/svgs/agriculture.svg" alt="" class="w-[32px]" />
            <h3 class="heading-regular text-cyan-1000">Private Healthcare</h3>
            <p class="text-lg-regular text-cyan-0">We care about the wellbeing of our team. That's why we offer private
              healthcare, giving you access to additional medical support and helping you look after your health when
              you need it most.
            </p>
          </div>
          <div class="flex flex-col gap-[20px]">
            <img src="/assets/svgs/agriculture.svg" alt="" class="w-[32px]" />
            <h3 class="heading-regular text-cyan-1000">Pension Scheme</h3>
            <p class="text-lg-regular text-cyan-0">Benefit from a workplace pension scheme designed to help you save for
              the future.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Open Roles -->
<section class="bg-navy-0">
  <div class="container py-[100px]">
    <div class="flex flex-col gap-[20px]">
      <h2 class="subheading-regular text-dark-blue-1000">Open Roles</h2>

      {% if collections.roles | length %}
      <ul class="role-list">
        {% for role in collections.roles %}
        <li class="flex flex-col gap-[10px] group">
          <a href="{{ role.url }}">
            <div class="flex flex-col lg:flex-row justify-between gap-[20px] lg:items-center py-[20px]">
              <div class="flex flex-col gap-[10px]">
                <h3 class="title-medium text-navy-1000">{{ role.data.title }}</h3>
                <div class="flex flex-row gap-[20px] items-center">
                  <div class="flex flex-row gap-[10px] items-center">
                    <img src="/assets/svgs/tools.svg" alt="" class="w-[18px] text-navy-1000" />
                    <p class="text-navy-1000 text-sm-light">{{ role.data.location }}</p>
                  </div>
                  <div class="flex flex-row gap-[10px]">
                    <img src="/assets/svgs/tools.svg" alt="" class="w-[18px] text-navy-1000" />
                    <p class="text-navy-1000 text-sm-light">{{ role.data.contract }}</p>
                  </div>
                </div>
              </div>
              <div class=" flex gap-[8px]">
                <p class="text-sm-bold text-navy-1000">View role &amp; apply</p>
                <svg class="w-[16px] transition duration-300 ease-out group-hover:translate-x-[8px] text-navy-1000"
                  viewBox="0 0 19 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1.66797 7H17.668M17.668 7L11.668 1M17.668 7L11.668 13" stroke="currentColor"
                    stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>
            </div>
            <hr class="text-dark-blue-200 border-[1px]" />
          </a>
        </li>
        {% endfor %}
      </ul>
      {% else %}
      <p>There are no open positions at the moment. Please upload your CV at the bottom of the page and we will let you
        know if a role becomes available that you are a good fit for.</p>
      {% endif %}
    </div>
  </div>
</section>

